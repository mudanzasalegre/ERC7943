# -------- uAgri dApp environment --------
# If you leave all chain address values empty, the app runs in DEMO MODE.
# Configure addresses per chain to enable ON-CHAIN MODE for that network.

# Base mainnet (chainId 8453)
NEXT_PUBLIC_BASE_MAINNET_CAMPAIGN_FACTORY=
NEXT_PUBLIC_BASE_MAINNET_CAMPAIGN_REGISTRY=
NEXT_PUBLIC_BASE_MAINNET_ROLE_MANAGER=

# Base Sepolia (chainId 84532)
NEXT_PUBLIC_BASE_SEPOLIA_CAMPAIGN_FACTORY=
NEXT_PUBLIC_BASE_SEPOLIA_CAMPAIGN_REGISTRY=
NEXT_PUBLIC_BASE_SEPOLIA_ROLE_MANAGER=

# Optional legacy fallback (applies to all supported chains if chain-specific vars are missing)
NEXT_PUBLIC_CAMPAIGN_FACTORY=
NEXT_PUBLIC_CAMPAIGN_REGISTRY=
NEXT_PUBLIC_ROLE_MANAGER=

# WalletConnect (optional): must be a valid 32-char hex project id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional custom RPCs (defaults to chain RPCs if empty)
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# Optional read-only default chain (base | base-sepolia). If empty, app auto-selects.
NEXT_PUBLIC_DEFAULT_CHAIN=

# Optional discovery scan start block (uint)
NEXT_PUBLIC_DISCOVERY_FROM_BLOCK=
